@model IEnumerable<ClassicCarsWeb.Models.TestDriveRequest>

<h2>Test Drive Bookings</h2>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Car Model</th>
            <th>Date</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.CustomerName</td>
                <td>@item.CarModel</td>
                <td>@item.BookingDate</td>
            </tr>
        }
    </tbody>
</table>