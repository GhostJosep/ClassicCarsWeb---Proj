@model ClassicCarsWeb.Models.Car

<div class="col-sm-6 col-md-4 mb-4">
    <div class="card h-100 classic-card classic-card-trigger text-light"
         data-title="@Model.Title" data-img="@Model.ImageUrl"
         data-make="@Model.Make" data-year="@Model.Year"
         data-engine="@Model.Engine" data-hp="@Model.Horsepower">
    
        <div class="compare-checkbox-container" onclick="event.stopPropagation();">
            <input type="checkbox" class="compare-check" data-id="@Model.Title" data-title="@Model.Title" data-engine="@Model.Engine" data-hp="@Model.Horsepower" data-year="@Model.Year" data-img="@Model.ImageUrl">
            <label class="small text-white ms-1 fw-bold" style="font-size:0.65rem; cursor:pointer;">COMPARE</label>
        </div>

        <div class="card-img-wrapper">
            <img src="@Model.ImageUrl" alt="@Model.Title" onerror="this.src='https://placehold.co/600x400/2b2b2b/eeeeee?text=Classic+Car'"/>
            <div class="card-hover-overlay">
                <div class="text-white mb-1" style="font-size: 0.75rem; letter-spacing: 1px; color:#dc3545 !important; font-weight:700;">SPECIFICATIONS</div>
                <div class="text-white small fw-semibold">⚙️ @Model.Engine</div>
                <div class="text-white small fw-semibold">🐎 @Model.Horsepower HP</div>
                <div class="text-white small fw-semibold">🚗 @Model.BodyStyle</div>
                <div class="text-white small fw-semibold">🕹️ @Model.Transmission</div>
            </div>
        </div>
        
        <div class="card-body d-flex flex-column justify-content-between gap-2">
            <h5 class="card-title m-0" style="font-size: 1.1rem; font-weight: 600;">@Model.Title</h5>
            <div>
                <span class="badge bg-danger me-1">@Model.Year</span>
                <span class="badge bg-secondary">@Model.Make</span>
            </div>
           <button type="button" 
        class="btn btn-danger test-drive-btn" 
        onclick="window.openTestDriveModal(event, '@Model.Title')">
    Book Test Drive
</button>

            <a asp-controller="Home" 
               asp-action="Details" 
               asp-route-id="@Model.ID" 
               class="btn btn-outline-secondary btn-sm w-100">
                View Details
            </a>
        </div>
    </div>
</div>