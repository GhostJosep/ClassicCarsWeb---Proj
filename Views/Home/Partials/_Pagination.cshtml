@if ((int)ViewData["TotalPages"] > 1)
{
    <div class="col-12 mt-2">
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @((int)ViewData["CurrentPage"] == 1 ? "disabled" : "")">
                    <a class="page-link page-link-dark" href="@Url.Action("Index", new { page = (int)ViewData["CurrentPage"] - 1 })">&laquo;</a>
                </li>
                @for (int i = 1; i <= (int)ViewData["TotalPages"]; i++)
                {
                    <li class="page-item @((int)ViewData["CurrentPage"] == i ? "active" : "")">
                        <a class="page-link page-link-dark" href="@Url.Action("Index", new { page = i })">@i</a>
                    </li>
                }
                <li class="page-item @((int)ViewData["CurrentPage"] == (int)ViewData["TotalPages"] ? "disabled" : "")">
                    <a class="page-link page-link-dark" href="@Url.Action("Index", new { page = (int)ViewData["CurrentPage"] + 1 })">&raquo;</a>
                </li>
            </ul>
        </nav>
    </div>
}